{
  "name": "precurator",
  "version": "0.1.0",
  "description": "Cybernetic control primitives for AI agents on top of LangGraph.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.2.17",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "tsc --noEmit -p tsconfig.types.json",
    "test:packaging": "bun run build && node tests/packaging/smoke.mjs",
    "verify": "bun run typecheck && bun run test && bun run test:types && bun run build && bun run test:packaging"
  },
  "peerDependencies": {
    "@langchain/core": "^1.1.33",
    "@langchain/langgraph": "^1.2.3",
    "zod": "^3.25.32 || ^4.2.0"
  },
  "devDependencies": {
    "@langchain/core": "1.1.33",
    "@langchain/langgraph": "1.2.3",
    "@types/node": "25.5.0",
    "expect-type": "1.3.0",
    "typescript": "5.9.3",
    "tsup": "8.5.1",
    "vitest": "4.1.0",
    "zod": "4.3.6"
  }
}
